# =====================================================================
# New Life Tagum — Environment variables
# Copy to .env.local for local dev. Set these in the Vercel dashboard for
# production. Never commit real secrets.
# =====================================================================

# --- Supabase (required) ---------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe for the browser; RLS-enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site (required) -------------------------------------------------
# Canonical site URL (no trailing slash). Used for metadata, sitemap,
# canonical URLs, email links, and auth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Super Admin bootstrap (recommended) -----------------------------
# The email that should be promoted to super_admin. After this user signs
# up, run `node scripts/setup-super-admin.mjs` (or it is auto-promoted on
# signup if app.super_admin_email is configured on the database).
SUPER_ADMIN_EMAIL=

# --- Privacy ---------------------------------------------------------
# Salt used to hash IP addresses before storing them (anti-spam keying).
# Use any long random string.
IP_HASH_SALT=change-me-to-a-long-random-string

# --- Resend transactional email (OPTIONAL) ---------------------------
# Leave blank to disable email. When unset, the app still works fully;
# confirmation emails are simply skipped.
RESEND_API_KEY=
# Verified sender, e.g. "New Life Tagum <hello@yourchurch.org>"
RESEND_FROM_EMAIL=
